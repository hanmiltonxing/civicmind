{
  "manifest_version": 3,
  "name": "CivicMind",
  "version": "1.1",
  "description": "A cognitive risk awareness tool that helps readers spot framing, question missing context, and compare perspectives.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open CivicMind on this page"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["sidebar.css"]
    }
  ]
}
