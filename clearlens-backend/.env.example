LLM_PROVIDER=vertex_ai

# Vertex AI mode
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_ENDPOINT=projects/your-gcp-project-id/locations/us-central1/endpoints/1234567890123456789
VERTEX_AI_PREDICTION_HOST=

# Ollama mode
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:latest

GOOGLE_AUTH_TIMEOUT_SECONDS=8
CLEARLENS_MAX_ANALYSIS_ATTEMPTS=3
# For local development only if you are not using gcloud ADC:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
